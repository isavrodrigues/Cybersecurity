{
  "manifest_version": 2,
  "name": "Privacy Guard",
  "version": "1.0",
  "description": "Detecta rastreadores, cookies, fingerprinting e violacoes de privacidade",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "webNavigation",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["js/trackers-list.js", "js/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Privacy Guard"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
